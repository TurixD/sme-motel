# --- Logs (se generan localmente) ---
logs/*.log
logs/*.log.*
!logs/.gitkeep

# --- Recibos subidos (archivos del usuario) ---
uploads/recibos/*
!uploads/recibos/.gitkeep
database/recibos/

# --- Reportes generados ---
reportes/

# --- Editor / SO ---
.vscode/
.idea/
Thumbs.db
desktop.ini
.DS_Store

